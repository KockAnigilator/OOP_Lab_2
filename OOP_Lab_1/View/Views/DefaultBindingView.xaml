<UserControl x:Class="View.Views.DefaultBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:View.Localization"
             mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Margin="0 0 0 8" CornerRadius="6" Background="#FF243044">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=DefaultBinding_Header}"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="0 0 0 4" />
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=DefaultBinding_Description}"
                           Foreground="#FFB0B8C5"
                           FontSize="12" />
            </StackPanel>
        </Border>

        <!-- Прямая привязка к свойству окна -->
        <Border Grid.Row="1" Padding="12" Margin="0 0 0 8" CornerRadius="6" Background="#FF1B2433">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=DefaultBinding_WindowBinding}"
                           Foreground="#FF9CC1FF"
                           FontWeight="SemiBold" />

                <TextBox Margin="0 6 0 4"
                         Height="28"
                         Background="#FF101726"
                         Foreground="White"
                         BorderBrush="#FF3D5A80"
                         BorderThickness="1"
                         Text="{Binding TextFromWindow,
                                        RelativeSource={RelativeSource AncestorType=Window}}">
                    <TextBox.ToolTip>
                        <TextBlock Text="Источник обновляется только при потере фокуса (LostFocus — значение по умолчанию)."
                                   TextWrapping="Wrap" />
                    </TextBox.ToolTip>
                </TextBox>

                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=DefaultBinding_CurrentWindowValue}"
                           Foreground="#FFB0B8C5"
                           FontSize="12" />
                <TextBlock Text="{Binding TextFromWindow, RelativeSource={RelativeSource AncestorType=Window}}"
                           Foreground="White"
                           FontWeight="Bold" />
            </StackPanel>
        </Border>

        <!-- Привязка через ViewModel -->
        <Border Grid.Row="2" Padding="12" Margin="0 0 0 8" CornerRadius="6" Background="#FF1B2433">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=DefaultBinding_ViewModelBinding}"
                           Foreground="#FF9CC1FF"
                           FontWeight="SemiBold" />

                <TextBox Margin="0 6 0 4"
                         Height="28"
                         Background="#FF101726"
                         Foreground="White"
                         BorderBrush="#FF3D5A80"
                         BorderThickness="1"
                         Text="{Binding ViewModelText}">
                    <TextBox.ToolTip>
                        <TextBlock Text="Та же привязка по умолчанию (LostFocus), но источник — свойство ViewModel."
                                   TextWrapping="Wrap" />
                    </TextBox.ToolTip>
                </TextBox>

                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=DefaultBinding_CurrentViewModelValue}"
                           Foreground="#FFB0B8C5"
                           FontSize="12" />
                <TextBlock Text="{Binding ViewModelText}"
                           Foreground="White"
                           FontWeight="Bold" />

                <TextBlock Margin="0 6 0 0"
                           Text="{Binding LastUpdated, StringFormat='Последнее обновление: {0:T}'}"
                           Foreground="#FFB0B8C5"
                           FontSize="11" />
            </StackPanel>
        </Border>

        <Button Grid.Row="3" Content="{Binding Source={StaticResource Loc}, Path=Button_ShowMessage}" Margin="0,0,0,8" Padding="8,4"
                Click="ShowMessage_Click" HorizontalAlignment="Left" />

        <TextBlock Grid.Row="4"
                   Margin="0 8 0 0"
                   TextWrapping="Wrap"
                   Foreground="#FF8A96A8"
                   FontSize="11">
            Обратите внимание: пока TextBox находится в фокусе, свойство источника НЕ обновляется.
            Значение меняется только при потере фокуса (клик вне поля или переход на другой контрол).
        </TextBlock>
    </Grid>
</UserControl>

