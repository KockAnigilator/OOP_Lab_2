<UserControl x:Class="View.Views.OneTimeBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:View.Localization"
             mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Margin="0 0 0 8" CornerRadius="6" Background="#FF243044">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=OneTime_Title}"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="0 0 0 4" />
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=OneTime_Description}"
                           Foreground="#FFB0B8C5"
                           FontSize="12" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Padding="12" Margin="0 0 0 8" CornerRadius="6" Background="#FF1B2433">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=OneTime_Compare}"
                           Foreground="#FF9CC1FF"
                           FontWeight="SemiBold" />

                <StackPanel Margin="0 8 0 4">
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=OneTime_Start}"
                               Foreground="#FFB0B8C5"
                               FontSize="12" />
                    <TextBlock FontSize="16"
                               Foreground="White"
                               Text="{Binding StartTime, Mode=OneTime, StringFormat={}{0:G}}" />
                </StackPanel>

                <StackPanel Margin="0 8 0 4">
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=OneTime_Current}"
                               Foreground="#FFB0B8C5"
                               FontSize="12" />
                    <TextBlock FontSize="16"
                               Foreground="White"
                               Text="{Binding CurrentTime, StringFormat={}{0:T}}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="0 8 0 0"
                   TextWrapping="Wrap"
                   Foreground="#FF8A96A8"
                   FontSize="11"
                   Text="{Binding Source={StaticResource Loc}, Path=OneTime_Note}" />
    </Grid>
</UserControl>

